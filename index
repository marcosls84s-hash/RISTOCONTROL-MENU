<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Menù Digitale - RistoControl</title>
    <!-- Carichiamo Firebase -->
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js"></script>
    <style>
        :root { --primary: #FF9800; --bg: #F4F7F6; }
        body { font-family: 'Segoe UI', Roboto, sans-serif; background-color: var(--bg); margin: 0; padding: 0; }
        .header { background: white; padding: 30px 20px; text-align: center; border-bottom: 5px solid var(--primary); box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
        .header h1 { margin: 0; color: var(--primary); font-size: 26px; text-transform: uppercase; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; }
        .status { text-align: center; padding: 40px; color: #888; font-size: 16px; }
        .category-header { background: var(--primary); color: white; padding: 8px 15px; border-radius: 8px; margin-top: 25px; font-weight: bold; text-transform: uppercase; }
        .dish { background: white; padding: 15px; margin: 10px 0; border-radius: 12px; display: flex; justify-content: space-between; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
        .dish-name { font-weight: 600; color: #333; }
        .dish-price { font-weight: bold; color: var(--primary); }
    </style>
</head>
<body>
    <div class="header">
        <h1 id="resName">RISTOCONTROL</h1>
        <p>Benvenuti - Menù Digitale</p>
    </div>
    <div class="container">
        <div id="status" class="status">Tentativo di connessione al database...</div>
        <div id="menu"></div>
    </div>

    <script>
        // CONFIGURAZIONE FIREBASE
        const config = { databaseURL: "https://comandaristorante-facile-default-rtdb.europe-west1.firebasedatabase.app" };
        firebase.initializeApp(config);
        const db = firebase.database();

        // Recupero l'ID del ristorante dalla URL (?res=xxxx)
        const resId = new URLSearchParams(window.location.search).get('res');
        const statusDiv = document.getElementById('status');
        const menuDiv = document.getElementById('menu');

        if (!resId) {
            statusDiv.innerHTML = "❌ Errore: Link non valido. Scansiona il QR Code del ristorante.";
        } else {
            statusDiv.innerHTML = "Caricamento menù in corso...";
            
            // Riferimento al tuo database
            const resRef = db.ref("restaurants/" + resId);

            // Carichiamo il nome del ristorante
            resRef.child("info/name").on("value", (s) => {
                if (s.exists()) document.getElementById('resName').innerText = s.val().toUpperCase();
            });

            // Carichiamo i piatti
            resRef.child("menu").on("value", (snapshot) => {
                if (!snapshot.exists()) {
                    statusDiv.innerHTML = "📭 Il menù di questo ristorante è attualmente vuoto.";
                    return;
                }

                statusDiv.style.display = 'none';
                menuDiv.innerHTML = "";
                
                const dishes = [];
                snapshot.forEach(child => { dishes.push(child.val()); });

                // Raggruppa per categoria
                const categories = [...new Set(dishes.map(d => d.category))];

                categories.forEach(cat => {
                    const catEl = document.createElement('div');
                    catEl.className = 'category-header';
                    catEl.innerText = cat;
                    menuDiv.appendChild(catEl);

                    dishes.filter(d => d.category === cat).forEach(d => {
                        const dishEl = document.createElement('div');
                        dishEl.className = 'dish';
                        dishEl.innerHTML = `<span class="dish-name">${d.name}</span><span class="dish-price">€ ${d.price.toFixed(2)}</span>`;
                        menuDiv.appendChild(dishEl);
                    });
                });
            }, (error) => {
                statusDiv.innerHTML = "⚠️ Errore di accesso: " + error.message + "<br><br>Verifica le regole del database (Rules) su Firebase.";
            });
        }
    </script>
</body>
</html>
