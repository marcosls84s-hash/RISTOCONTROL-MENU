<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Menù Digitale - RistoControl</title>
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-database-compat.js"></script>
    <style>
        body { font-family: sans-serif; text-align: center; padding: 50px; background: #f4f4f4; }
        .card { background: white; padding: 20px; border-radius: 10px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); display: inline-block; min-width: 300px; }
        h1 { color: #FF9800; }
        .item { display: flex; justify-content: space-between; border-bottom: 1px solid #eee; padding: 10px 0; }
        #debug { color: red; font-size: 12px; margin-top: 20px; }
    </style>
</head>
<body>
    <div class="card">
        <h1 id="title">RISTOCONTROL</h1>
        <div id="menu">Caricamento in corso...</div>
        <div id="debug"></div>
    </div>

    <script>
        // Configurazione
        const config = { databaseURL: "https://comandaristorante-facile-default-rtdb.europe-west1.firebasedatabase.app" };
        firebase.initializeApp(config);
        
        const params = new URLSearchParams(window.location.search);
        const resId = params.get('res');
        const debug = document.getElementById('debug');

        if (!resId) {
            document.getElementById('menu').innerHTML = "⚠️ Link non valido. Usa il QR del tavolo.";
        } else {
            debug.innerText = "Connessione al database per: " + resId;
            const ref = firebase.database().ref("restaurants/" + resId);

            // Carica nome
            ref.child("info/name").on("value", (s) => {
                if(s.exists()) document.getElementById('title').innerText = s.val().toUpperCase();
            });

            // Carica menu
            ref.child("menu").on("value", (snap) => {
                const menuDiv = document.getElementById('menu');
                if (snap.exists()) {
                    menuDiv.innerHTML = "";
                    snap.forEach((child) => {
                        const p = child.val();
                        menuDiv.innerHTML += `<div class="item"><span>${p.name}</span><b>€${p.price.toFixed(2)}</b></div>`;
                    });
                    debug.innerText = "Menù caricato con successo!";
                    debug.style.color = "green";
                } else {
                    menuDiv.innerHTML = "Il menù di questo locale è vuoto.";
                    debug.innerText = "Errore: Nessun dato trovato nel percorso specificato.";
                }
            }, (error) => {
                debug.innerText = "Errore Firebase: " + error.message;
            });
        }
    </script>
</body>
</html>
