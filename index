<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Menù Digitale</title>
    <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-database.js"></script>
    <style>
        body { font-family: sans-serif; padding: 20px; background: white; text-align: center; }
        .box { border: 2px solid #FF9800; padding: 20px; border-radius: 10px; margin-top: 20px; }
        h1 { color: #FF9800; }
        .piatto { display: flex; justify-content: space-between; padding: 10px; border-bottom: 1px solid #eee; text-align: left; }
        #errori { color: red; font-weight: bold; margin-top: 20px; }
    </style>
</head>
<body>

    <h1 id="nomeLocale">RISTOCONTROL MENU</h1>
    <div id="errori"></div>
    
    <div id="listaMenu">
        <p>In attesa di caricamento...</p>
    </div>

    <script>
        // MESSAGGIO DI PARTENZA
        alert("Sito avviato! Controllo connessione...");

        const config = { databaseURL: "https://comandaristorante-facile-default-rtdb.europe-west1.firebasedatabase.app" };
        
        try {
            firebase.initializeApp(config);
            const db = firebase.database();

            // Leggiamo l'ID dalla URL
            const params = new URLSearchParams(window.location.search);
            const resId = params.get('res');

            if (!resId) {
                alert("ERRORE: Manca l'ID del ristorante nel link!");
                document.getElementById('errori').innerHTML = "ERRORE: Manca il codice ristorante nell'indirizzo!";
            } else {
                alert("ID Rilevato: " + resId + ". Cerco i piatti...");
                
                db.ref("restaurants/" + resId).on("value", (snapshot) => {
                    if (snapshot.exists()) {
                        const data = snapshot.val();
                        alert("Dati trovati per: " + (data.info ? data.info.name : "Ristorante"));

                        // Nome Locale
                        if (data.info && data.info.name) {
                            document.getElementById('nomeLocale').innerText = data.info.name.toUpperCase();
                        }

                        // Lista Piatti
                        const menuDiv = document.getElementById('listaMenu');
                        menuDiv.innerHTML = "";
                        
                        if (data.menu) {
                            const dishes = Object.values(data.menu);
                            alert("Trovati " + dishes.length + " piatti!");
                            dishes.forEach(piatto => {
                                menuDiv.innerHTML += `
                                    <div class="piatto">
                                        <span>${piatto.name}</span>
                                        <b>€ ${piatto.price.toFixed(2)}</b>
                                    </div>`;
                            });
                        } else {
                            menuDiv.innerHTML = "Il menù è presente ma non ci sono piatti all'interno.";
                        }

                    } else {
                        alert("ERRORE: Ristorante non trovato nel database!");
                    }
                }, (error) => {
                    alert("ERRORE DI PERMESSO: " + error.message);
                });
            }
        } catch (e) {
            alert("ERRORE DELLO SCRIPT: " + e.message);
        }
    </script>
</body>
</html>
