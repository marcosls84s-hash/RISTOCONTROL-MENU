<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DEBUG Menù - RistoControl</title>
    <!-- Firebase SDK v8 (molto stabile per web statico) -->
    <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
    <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-database.js"></script>
    <style>
        body { font-family: sans-serif; background: #222; color: #fff; padding: 20px; text-align: center; }
        .log-box { background: #000; color: #0f0; padding: 15px; border-radius: 8px; text-align: left; font-family: monospace; font-size: 12px; margin-bottom: 20px; border: 1px solid #444; }
        .menu-container { background: #fff; color: #333; border-radius: 15px; padding: 20px; display: none; }
        .dish { display: flex; justify-content: space-between; border-bottom: 1px solid #eee; padding: 10px 0; font-weight: bold; }
        .category { background: #FF9800; color: #fff; padding: 5px; margin-top: 15px; border-radius: 5px; }
        h1 { color: #FF9800; margin-bottom: 5px; }
    </style>
</head>
<body>

    <h1>RISTOCONTROL</h1>
    <p>Diagnostica Connessione Menù</p>

    <!-- BOX DI LOG PER CAPIRE COSA SUCCEDE -->
    <div id="log" class="log-box">Log: Inizializzazione...</div>

    <!-- IL MENU VERO E PROPRIO -->
    <div id="menuUI" class="menu-container">
        <h2 id="resTitle">Nome Ristorante</h2>
        <div id="itemsList"></div>
    </div>

    <script>
        const log = document.getElementById('log');
        function addLog(msg) { log.innerHTML += "<br>> " + msg; }

        try {
            // 1. Configurazione
            const config = { databaseURL: "https://comandaristorante-facile-default-rtdb.europe-west1.firebasedatabase.app" };
            firebase.initializeApp(config);
            addLog("Firebase inizializzato.");

            // 2. Lettura ID
            const urlParams = new URLSearchParams(window.location.search);
            const resId = urlParams.get('res');

            if (!resId) {
                addLog("ERRORE: Manca l'ID del ristorante nel link (?res=...)");
            } else {
                addLog("ID Ristorante rilevato: " + resId);
                const db = firebase.database();
                const ref = db.ref("restaurants/" + resId);

                // 3. Test caricamento Nome
                ref.child("info/name").on("value", (snap) => {
                    if (snap.exists()) {
                        addLog("Nome trovato: " + snap.val());
                        document.getElementById('resTitle').innerText = snap.val().toUpperCase();
                        document.getElementById('menuUI').style.display = 'block';
                    } else {
                        addLog("ATTENZIONE: Nessun nome trovato per questo ID.");
                    }
                });

                // 4. Caricamento Piatti
                ref.child("menu").on("value", (snap) => {
                    const list = document.getElementById('itemsList');
                    list.innerHTML = "";
                    if (snap.exists()) {
                        addLog("Piatti trovati nel database!");
                        let currentCat = "";
                        snap.forEach((child) => {
                            const d = child.val();
                            if (d.category !== currentCat) {
                                currentCat = d.category;
                                list.innerHTML += `<div class="category">${currentCat.toUpperCase()}</div>`;
                            }
                            list.innerHTML += `<div class="dish"><span>${d.name}</span><span>€${d.price.toFixed(2)}</span></div>`;
                        });
                    } else {
                        addLog("ERRORE: La cartella 'menu' è vuota nel database.");
                    }
                }, (error) => {
                    addLog("ERRORE DATABASE: " + error.message);
                });
            }
        } catch (e) {
            addLog("CRASH JAVASCRIPT: " + e.message);
        }
    </script>
</body>
</html>
